Options -Indexes
RewriteEngine On

# ============================================================
# MODO LOCAL (XAMPP/subpasta):
#   - Descomente a linha RewriteBase abaixo substituindo
#     "projeto-agenda-php" pelo nome real da sua pasta.
# MODO PRODUÇÃO (raiz do domínio):
#   - Deixe RewriteBase comentado.
# ============================================================

# RewriteBase /projeto-agenda-php/

# Arquivos/pastas físicos — serve direto (exceto chamadas à API)
RewriteCond %{REQUEST_URI} !^(/[^/]+)?/api
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Raiz → SPA
RewriteRule ^$ src/index.html [L]

# Rotas da API → api.php
RewriteRule ^api/(.+)$ api.php?_route=$1 [QSA,L]
RewriteRule ^api$       api.php          [QSA,L]

# login / logout (acesso direto via URL amigável)
RewriteRule ^login$  login.php  [L]
RewriteRule ^logout$ logout.php [L]
