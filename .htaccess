Options -Indexes
RewriteEngine On

# ============================================================
# MODO LOCAL (XAMPP/subpasta): descomente RewriteBase abaixo
# MODO HOSTGATOR (raiz do domínio): deixe RewriteBase comentado
# ============================================================

# RewriteBase /projeto-agenda-php/

# Arquivos/pastas físicos — serve direto (exceto chamadas à api)
RewriteCond %{REQUEST_URI} !^(/projeto-agenda-php)?/api
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Raiz → SPA
RewriteRule ^$ src/index.html [L]

# Rotas da API → api.php
RewriteRule ^api/(.+)$ api.php?_route=$1 [QSA,L]
RewriteRule ^api$       api.php          [QSA,L]

# login / logout
RewriteRule ^login$  login.php  [L]
RewriteRule ^logout$ logout.php [L]