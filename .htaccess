Options -Indexes
RewriteEngine On

# Redireciona raiz para a SPA
RewriteRule ^$ src/index.html [L]

# Rotas da API: /api/* → api.php
RewriteRule ^api/(.*)$ api.php?_route=$1 [QSA,L]

# Login / logout
RewriteRule ^login$  login.php  [L]
RewriteRule ^logout$ logout.php [L]

# Arquivos estáticos existentes: serve direto
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
